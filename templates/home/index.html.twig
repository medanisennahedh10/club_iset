{% extends 'base.html.twig' %}

{% block title %}Club_ISET — Plateforme professionnelle{% endblock %}

{% block body %}

{# NAVBAR #}
<header class="navbar">
    <div class="navbar-inner">
        <a href="/" class="navbar-brand">
            <span class="brand-name">Club_<span class="brand-accent">ISET</span></span>
        </a>

        <nav class="navbar-nav">

        </nav>

        <div class="navbar-actions">
            <a href="/login" class="btn btn-ghost">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                Connexion
            </a>
        </div>

        <button class="navbar-toggle" aria-label="Menu" onclick="this.closest('.navbar').classList.toggle('open')">
            <span></span><span></span><span></span>
        </button>
    </div>

    <div class="navbar-mobile">
        <a href="/login" class="btn btn-ghost btn-block">Connexion</a>
        <a href="/register" class="btn btn-primary btn-block">S'inscrire</a>
    </div>
</header>

{# HERO #}
<section class="hero">
    <div class="hero-bg">
        <div class="hero-blob hero-blob-1"></div>
        <div class="hero-blob hero-blob-2"></div>
        <div class="hero-grid"></div>
    </div>

    <div class="container hero-inner">


        <h1 class="hero-title">
            Un club, une équipe ,  <br>
            <span class="text-accent">un avenir qu’on construit ensemble.</span>
        </h1>


        <div class="hero-actions">
            <a href="/register" class="btn btn-primary btn-lg">
                Créer mon compte
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
        </div>

        <div class="hero-stats">
            <div class="stat-item">
                <span class="stat-number">3000+</span>
                <span class="stat-label">Utilisateurs actifs</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-number">99.9%</span>
                <span class="stat-label">Disponibilité</span>
            </div>

        </div>
    </div>
</section>

{# FEATURES #}

            <section class="features section" id="fonctionnalites">
    <div class="container">
        <div class="section-header">
            <p class="section-tag">Fonctionnalités</p>
            <h2 class="section-title">Une plateforme complète pour les clubs</h2>
            <p class="section-sub">
                Gérez les clubs, les événements et les recrutements depuis une seule plateforme.
            </p>
        </div>

        <div class="features-grid">

            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="7" height="7"/>
                        <rect x="14" y="3" width="7" height="7"/>
                        <rect x="14" y="14" width="7" height="7"/>
                        <rect x="3" y="14" width="7" height="7"/>
                    </svg>
                </div>

                <h3>Tableau de bord centralisé</h3>
                <p>
                    Visualisez les clubs, événements, candidatures et statistiques
                    depuis une seule interface.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>

                <h3>Gestion des clubs</h3>
                <p>
                    Les administrateurs peuvent créer, gérer et organiser
                    les clubs facilement.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="20" x2="18" y2="10"/>
                        <line x1="12" y1="20" x2="12" y2="4"/>
                        <line x1="6" y1="20" x2="6" y2="14"/>
                    </svg>
                </div>

                <h3>Suivi des participations</h3>
                <p>
                    Analysez les inscriptions et la participation des étudiants
                    aux événements.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                </div>

                <h3>Sécurité avancée</h3>
                <p>
                    Authentification sécurisée, gestion des rôles et protection
                    des données utilisateurs.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                </div>

                <h3>Gestion des événements</h3>
                <p>
                    Planifiez des événements, gérez les dates et les inscriptions
                    en quelques clics.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                </div>

                <h3>Plateforme évolutive</h3>
                <p>
                    Architecture flexible permettant d’ajouter de nouvelles
                    fonctionnalités selon les besoins.
                </p>
            </div>

        </div>
    </div>
</section>

{# FOOTER #}
<footer class="footer">
    <div class="container footer-inner">
        <div class="footer-brand">
            <a href="/" class="navbar-brand">
                <span class="brand-name">Club_ISET<span class="brand-accent"></span></span>
            </a>
        </div>

        <div class="footer-links">
            <div class="footer-col">
                <h4>Localisation</h4>
                <a href="#">zaghouan - magren </a>
            </div>
            <div class="footer-col">
                <h4>téléphone</h4>
                <a href="#">+216 72 660 400</a>
                <a href="#">+216 72 660 700</a>
            </div>
            <div class="footer-col">
                <h4>Email</h4>
                <a href="#">iset.zg@zaghouan.r-iset.tn</a>
            </div>
        </div>
    </div>
</footer>

{% endblock %}
